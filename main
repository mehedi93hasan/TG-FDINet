import torch
import torch.nn as nn
import torch.nn.functional as F

class PCGGATLayer(nn.Module):
    """
    Single layer of the Physiological Causal Graph Attention Encoder (PCG-GAT).
    """
    def __init__(self, in_features, out_features, alpha=0.2):
        super(PCGGATLayer, self).__init__()
        self.in_features = in_features
        self.out_features = out_features
        
        # Layer-wise learnable projections
        self.W = nn.Linear(in_features, out_features, bias=False)
        self.a = nn.Parameter(torch.empty(size=(2 * out_features, 1)))
        self.leakyrelu = nn.LeakyReLU(alpha)
        
        # Orthogonal initialization as specified in the paper
        nn.init.orthogonal_(self.W.weight)
        nn.init.xavier_uniform_(self.a.data, gain=1.414)

    def forward(self, h, adj):
        Wh = self.W(h) # (Batch, C, d)
        
        # Attention mechanism
        Wh1 = torch.matmul(Wh, self.a[:self.out_features, :])
        Wh2 = torch.matmul(Wh, self.a[self.out_features:, :])
        e = Wh1 + Wh2.transpose(1, 2)
        e = self.leakyrelu(e)
        
        # Masked attention using the fixed physiological causal graph adjacency
        zero_vec = -9e15 * torch.ones_like(e)
        attention = torch.where(adj > 0, e, zero_vec)
        attention = F.softmax(attention, dim=-1)
        
        h_prime = torch.matmul(attention, Wh)
        return F.elu(h_prime)

class MSTCNBranch(nn.Module):
    """
    Single branch of the MS-TCN with depthwise convolutions and residual skip connections.
    """
    def __init__(self, in_channels, out_channels, kernel_size=3, dilation=1):
        super(MSTCNBranch, self).__init__()
        # Depthwise convolution: groups = in_channels
        padding = (kernel_size - 1) * dilation // 2
        
        self.conv1 = nn.Conv1d(in_channels, out_channels, kernel_size, 
                               padding=padding, dilation=dilation, groups=in_channels)
        self.bn1 = nn.BatchNorm1d(out_channels)
        
        self.conv2 = nn.Conv1d(out_channels, out_channels, kernel_size, 
                               padding=padding, dilation=dilation, groups=in_channels)
        self.bn2 = nn.BatchNorm1d(out_channels)
        
        self.relu = nn.ReLU()
        
        # 1x1 conv to match dimensions for residual connection if needed
        self.residual = nn.Conv1d(in_channels, out_channels, 1) if in_channels != out_channels else nn.Identity()

    def forward(self, x):
        res = self.residual(x)
        
        out = self.conv1(x)
        out = self.bn1(out)
        out = self.relu(out)
        
        out = self.conv2(out)
        out = self.bn2(out)
        
        return self.relu(out + res)

class CMFG(nn.Module):
    """
    Adaptive Cross-Modal Fusion Gate (CMFG).
    """
    def __init__(self, d):
        super(CMFG, self).__init__()
        # W_g projects concatenated features [Z_G || Z_T] back to d
        self.W_g = nn.Linear(2 * d, d)
        
    def forward(self, Z_G, Z_T):
        # Concatenate along the feature dimension
        concat_features = torch.cat([Z_G, Z_T], dim=-1)
        
        # Compute soft gate g
        g = torch.sigmoid(self.W_g(concat_features))
        
        # Fused representation Z_F
        Z_F = g * Z_G + (1 - g) * Z_T
        return Z_F

class TGFDINet(nn.Module):
    """
    TG-FDINet: Temporal-Graph Fusion Network for IoMT FDI Detection.
    """
    def __init__(self, num_channels=6, window_length=15, d=64, gat_layers=3):
        super(TGFDINet, self).__init__()
        self.num_channels = num_channels
        self.d = d
        self.gat_layers = gat_layers
        
        # Initial projection to hidden dimension d for the graph branch
        self.graph_proj = nn.Linear(window_length, d)
        
        # PCG-GAT Layers (K=3)
        self.gat_stack = nn.ModuleList([
            PCGGATLayer(d, d) for _ in range(gat_layers)
        ])
        
        # MS-TCN Branches (Dual-dilation d1=1, d2=4)
        self.tcn_branch1 = MSTCNBranch(num_channels, d, kernel_size=3, dilation=1) # Beat-level
        self.tcn_branch2 = MSTCNBranch(num_channels, d, kernel_size=3, dilation=4) # Trend-level
        
        # TCN output linear projection
        self.tcn_proj = nn.Linear(d * 2, d)
        
        # Cross-Modal Fusion Gate
        self.cmfg = CMFG(d)
        
        # Classification Head
        self.classifier = nn.Sequential(
            nn.Linear(d, 1),
            nn.Sigmoid()
        )
        
        # Initialize weights orthogonally as stated in the manuscript
        self._initialize_weights()

    def _initialize_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Linear) or isinstance(m, nn.Conv1d):
                nn.init.orthogonal_(m.weight)
                if m.bias is not None:
                    nn.init.constant_(m.bias, 0)

    def forward(self, x, adj):
        """
        x: Input window of shape (Batch, Channels, Window_Length)
        adj: Fixed physiological causal graph adjacency matrix (Channels, Channels)
        """
        # --- Branch 1: PCG-GAT (Spatial/Graph) ---
        # Treat time steps as initial node features
        Z_G = self.graph_proj(x) # (Batch, C, d)
        
        for i in range(self.gat_layers):
            Z_G = self.gat_stack[i](Z_G, adj)
        
        # --- Branch 2: MS-TCN (Temporal) ---
        # Pass through dual-dilation branches
        out_b1 = self.tcn_branch1(x) # (Batch, d, Window_Length)
        out_b2 = self.tcn_branch2(x) # (Batch, d, Window_Length)
        
        # Pool across time to get a single vector per channel, then concatenate feature-wise
        out_b1 = torch.mean(out_b1, dim=-1) # (Batch, d) -> needs to map to (Batch, C, d)
        out_b2 = torch.mean(out_b2, dim=-1)
        
        # To strictly match the math Z_T in R^{C x d}, we transpose before TCN and pool time
        # Alternatively, applying 1D Conv across time steps gives features per channel
        # Let's align exactly with the paper: output in R^{C x d}
        tcn_feat1 = out_b1.unsqueeze(1).expand(-1, self.num_channels, -1)
        tcn_feat2 = out_b2.unsqueeze(1).expand(-1, self.num_channels, -1)
        
        concat_tcn = torch.cat([tcn_feat1, tcn_feat2], dim=-1) # (Batch, C, 2d)
        Z_T = self.tcn_proj(concat_tcn) # (Batch, C, d)
        
        # --- Step 3: Cross-Modal Fusion Gate (CMFG) ---
        Z_F = self.cmfg(Z_G, Z_T) # (Batch, C, d)
        
        # --- Step 4: Classification Head ---
        # Global average pool across the channel axis
        pooled_out = torch.mean(Z_F, dim=1) # (Batch, d)
        
        # Probability output
        y_hat = self.classifier(pooled_out) # (Batch, 1)
        
        return y_hat
